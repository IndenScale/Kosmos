# 秘钥配置
JWT_SECRET_KEY="JWT_SECRET_KEY"
JWT_REFRESH_SECRET_KEY="REFRESH_SECRET_KEY"
CREDENTIAL_ENCRYPTION_KEY="CREDENTIAL_ENCRYPTION_KEY"

# 数据库配置
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="PostgreSQL"

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN="root:Milvus"

# 去重配置
DEDUP_ENABLED=true
DEDUP_LITERAL_ENABLED=true
DEDUP_SEMANTIC_ENABLED=true
DEDUP_SEMANTIC_THRESHOLD=0.5
DEDUP_MIN_LENGTH=10

# 启动端点
KOSMOS_SERVER_HOST=localhost
KOSMOS_SERVER_PORT=8000
KOSMOS_WEBUI_HOST=localhost
KOSMOS_WEBUI_PORT=3000

# PDF解析工具配置
MINERU_PATH=/path/to/mineru/executable